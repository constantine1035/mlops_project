{
  "id": null,
  "uid": "wine-dashboard",
  "title": "Wine Quality Service Dashboard",
  "schemaVersion": 16,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "graph",
      "id": 1,
      "title": "Prediction Requests per Second",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{path=\"/predict\"}[1m]))",
          "legendFormat": "req/s",
          "interval": ""
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "yaxes": [
        {"format": "short", "label": null, "logBase": 1, "min": 0},
        {"format": "short", "label": null, "logBase": 1}
      ],
      "xaxis": {"mode": "time"}
    }
  ],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser"
}